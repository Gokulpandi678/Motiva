NODE_ENV=development

DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

LOG_LEVEL=info

# --- WorkOS AuthKit --------------------------------------------------------
# Create a project at https://dashboard.workos.com to get real values for
# these two. WORKOS_API_KEY is a secret — never commit a real one.
WORKOS_CLIENT_ID=client_your_workos_client_id
WORKOS_API_KEY=sk_your_workos_api_key

# Must exactly match a Redirect URI configured in the WorkOS dashboard. Now
# points at this same Next.js app's own route (frontend + API are one app/
# one origin post-migration), whereas before it pointed at the separate
# Express server on port 4000.
WORKOS_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# Where the browser lands after login/logout completes. Still a dedicated
# route that reads the token fragment from the URL (see AuthCallbackPage).
WEB_APP_URL=http://localhost:3000

# How long (seconds) a pending login's PKCE state/codeVerifier stays valid
# server-side between /api/v1/auth/login and /api/v1/auth/callback.
OAUTH_STATE_TTL_SECONDS=600
