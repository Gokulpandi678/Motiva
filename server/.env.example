NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

LOG_LEVEL=info

CORS_ORIGIN=http://localhost:5173

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- WorkOS AuthKit --------------------------------------------------------
# Create a project at https://dashboard.workos.com to get real values for
# these two. WORKOS_API_KEY is a secret — never commit a real one.
WORKOS_CLIENT_ID=client_your_workos_client_id
WORKOS_API_KEY=sk_your_workos_api_key

# Must exactly match a Redirect URI configured in the WorkOS dashboard. This
# is the BACKEND's own callback route — it exchanges the code, then redirects
# the browser to WEB_APP_URL with the tokens in a URL fragment.
WORKOS_REDIRECT_URI=http://localhost:4000/api/v1/auth/callback

# Where the browser lands after login/logout completes. The frontend must
# have a route here that reads the token fragment (see AuthCallbackPage).
WEB_APP_URL=http://localhost:5173

# How long (seconds) a pending login's PKCE state/codeVerifier stays valid
# server-side between /auth/login and /auth/callback.
OAUTH_STATE_TTL_SECONDS=600
