      "item": [
        {
          "name": "Create Ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('ticketId', body.data.id);",
                  "  if (body.data.faq) pm.collectionVariables.set('faqId', body.data.faq.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"title\": \"Fix Redis connection timeouts in prod\",\n  \"problem\": \"Redis client kept dropping connections under load, causing 500s on the cache layer.\",\n  \"status\": \"OPEN\",\n  \"difficulty\": \"MEDIUM\",\n  \"tags\": [\"redis\", \"nodejs\", \"performance\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets"]
            }
          },
          "response": []
        },
        {
          "name": "List Tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets?page=1&limit=20",
